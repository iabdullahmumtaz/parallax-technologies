# Optional: Calendly booking page, Google Calendar appointment schedule, or Cal.com link
NEXT_PUBLIC_SCHEDULING_URL=

# Optional: Google Meet room URL (e.g. https://meet.google.com/xxx-xxxx-xxx)
NEXT_PUBLIC_GOOGLE_MEET_URL=

# EmailJS (https://www.emailjs.com/) — contact form
# Dashboard: Account → API keys (Public Key); Email Services → Service ID; Email Templates → Template ID
# Template content should reference: {{from_name}}, {{from_email}}, {{company}}, {{message}}
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
